    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@600;800&family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-dark: #050208;
            --card-glass: rgba(255, 255, 255, 0.05);
        }

        /* --- DYNAMIC COLOR ANIMATION --- */
        @keyframes colorShift {
            0% { --glow-color: #a020f0; --text-glow: #d8b4fe; } /* Purple */
            33% { --glow-color: #00eaff; --text-glow: #b4f0fe; } /* Blue */
            66% { --glow-color: #ff6a00; --text-glow: #feb482; } /* Orange */
            100% { --glow-color: #a020f0; --text-glow: #d8b4fe; }
        }

        * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

        body {
            background: var(--bg-dark);
            color: #fff;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
            animation: colorShift 10s infinite linear;
        }

        header {
            display: flex; justify-content: space-between; align-items: center;
            padding: 15px 20px; background: rgba(0,0,0,0.9);
            position: sticky; top: 0; z-index: 1000; border-bottom: 1px solid var(--glow-color);
            transition: border 0.5s ease;
        }
        .logo { font-family: 'Poppins'; font-weight: 800; color: #fff; }
        .info-btn { font-size: 12px; cursor: pointer; color: #fff; border: 1px solid var(--glow-color); padding: 5px 15px; border-radius: 50px; box-shadow: 0 0 10px var(--glow-color); }

        .hero { text-align: center; padding: 30px 20px; }
        .hero-img {
            width: 180px; height: 180px; border-radius: 50%;
            box-shadow: 0 0 30px var(--glow-color);
            margin-bottom: 20px; object-fit: cover;
            border: 3px solid var(--glow-color);
            transition: 0.5s ease;
        }
        
        .main-title {
            font-family: 'Poppins'; font-size: 2.3rem; font-weight: 800;
            color: var(--text-glow); text-transform: uppercase;
            text-shadow: 0 0 20px var(--glow-color); cursor: pointer;
        }

        .container { padding: 20px; max-width: 600px; margin: auto; }
        .section-label { font-family: 'Poppins'; font-size: 1.3rem; margin-bottom: 15px; display: block; color: var(--text-glow); }
        
        .card {
            background: var(--card-glass); border-radius: 20px;
            padding: 25px; margin-bottom: 25px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
        }
        .price-row { display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }

        /* --- CIRCULAR FLOW GLOW BUTTON --- */
        .glow-wrap {
            position: relative;
            display: flex; justify-content: center; align-items: center;
            width: 100%; height: 60px;
            background: #111; border-radius: 15px;
            overflow: hidden; margin-top: 15px;
        }

        /* The Moving Glow Light (Snake Effect) */
        .glow-wrap::before {
            content: '';
            position: absolute; width: 150%; height: 150%;
            background: conic-gradient(transparent, transparent, transparent, var(--glow-color));
            animation: rotateGlow 3s linear infinite;
        }

        .glow-wrap::after {
            content: ''; position: absolute; inset: 3px;
            background: #111; border-radius: 12px; z-index: 1;
        }

        @keyframes rotateGlow { 100% { transform: rotate(360deg); } }

        .btn-live {
            position: relative; z-index: 2;
            width: 100%; height: 100%;
            display: flex; justify-content: center; align-items: center;
            text-decoration: none; color: #fff; font-weight: 800;
            font-family: 'Poppins'; letter-spacing: 1px;
            background: transparent; border: none;
        }

        /* --- MODAL --- */
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: #000; z-index: 2000; overflow-y: auto; padding: 20px; }
        .modal-body { max-width: 500px; margin: 40px auto; background: #0f0a1a; border: 1px solid var(--glow-color); border-radius: 20px; padding: 25px; box-shadow: 0 0 30px var(--glow-color); }
        .close-x { float: right; font-size: 28px; cursor: pointer; color: var(--glow-color); }
        .telegram-msg { font-family: monospace; white-space: pre-wrap; background: rgba(0,0,0,0.5); padding: 15px; border-radius: 10px; color: #fff; font-size: 0.85rem; border: 1px solid var(--glow-color); }

        footer { text-align: center; padding: 40px; opacity: 0.5; font-size: 0.8rem; }
    </style>
</head>
